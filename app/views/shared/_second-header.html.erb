<header class='second-header'>
  <%= link_to image_tag("furima-logo-color.png", class:"second-logo"), "/" %>
  <div class="second-header-nav">
    <% if user_signed_in? %>
      <span><%= current_user.nickname %></span>
      <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class:"logout-btn" %>
    <% else %>
      <%= link_to "新規登録", new_user_registration_path, class:"signup-btn" %>
      <%= link_to "ログイン", new_user_session_path, class:"login-btn" %>
    <% end %>
  </div>
</header>